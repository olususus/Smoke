{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Smoke",
  "version": "0.0.1",
  "identifier": "dev.smoke.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "NEXT_PUBLIC_SMOKE_RELEASE=1 npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Smoke",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.github.com https://github.com https://ipc.localhost; img-src 'self' https://avatars.githubusercontent.com https://*.githubusercontent.com https://www.gravatar.com https://*.gravatar.com data: blob:",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
